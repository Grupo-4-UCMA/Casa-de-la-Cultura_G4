# ============================================================
# .gitignore - Proyecto La Casa de la Cultura
# Stack: Python + Django + SQLite
# ============================================================


# ------------------------------------------------------------
# Sistema operativo
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.Trash-*


# ------------------------------------------------------------
# Editores e IDEs
# ------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~


# ------------------------------------------------------------
# Office / temporales mientras se edita un documento
# ------------------------------------------------------------
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp


# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
# Bytecode y cachés
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribuciones / paquetes
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
MANIFEST

# Entornos virtuales
venv/
.venv/
env/
.env/
ENV/

# Testing y cobertura
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Type checkers
.mypy_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/


# ------------------------------------------------------------
# Django
# ------------------------------------------------------------
# Variables de entorno (¡NUNCA subir credenciales!)
.env
.env.local
.env.*.local

# Base de datos local SQLite (por si alguien la usa para pruebas)
*.sqlite3
*.sqlite3-journal
db.sqlite3

# Archivos estáticos recolectados y subidos por usuarios
/staticfiles/
/static_collected/
/media/

# Logs
*.log
logs/


# ------------------------------------------------------------
# Datos
# ------------------------------------------------------------
# Datos crudos del cliente: no se versionan (vienen de fuera del repo).
data/raw/

# Artefactos intermedios del pipeline de géneros: locales, regenerables.
data/prompts/
data/responses/

# Por defecto ignoramos todos los CSV bajo data/.
data/**/*.csv

# Excepciones: artefactos estables del ETL que sí versionamos para que
# el resto del equipo pueda arrancar el sistema sin re-ejecutar nada.
# Nota: ratings_clean_extended.csv NO se versiona por tamaño (~150 MB).
# Cada uno lo regenera en local con etl/etl_ratings_extended.py.
!data/clean/books_clean_final.csv
!data/clean/book_genres.csv
!data/clean/book_authors_extended.csv
!data/clean/copies_clean_extended.csv
!data/clean/users_clean.csv

# Otros formatos comprimidos pesados
*.csv.gz


# ------------------------------------------------------------
# Otros
# ------------------------------------------------------------
# Secretos y claves
*.pem
*.key
secrets.json
credentials.json

# Archivos comprimidos (normalmente no se versionan)
*.zip
*.tar
*.tar.gz
*.rar
