# ============================================================
# .gitignore - Proyecto La Casa de la Cultura
# Stack: Python + Django + PostgreSQL
# ============================================================


# ------------------------------------------------------------
# Sistema operativo
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.Trash-*


# ------------------------------------------------------------
# Editores e IDEs
# ------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~


# ------------------------------------------------------------
# Office / temporales mientras se edita un documento
# ------------------------------------------------------------
~$*.docx
~$*.xlsx
~$*.pptx
*.tmp


# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
# Bytecode y cachés
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribuciones / paquetes
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
MANIFEST

# Entornos virtuales
venv/
.venv/
env/
.env/
ENV/

# Testing y cobertura
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Type checkers
.mypy_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/


# ------------------------------------------------------------
# Django
# ------------------------------------------------------------
# Variables de entorno (¡NUNCA subir credenciales!)
.env
.env.local
.env.*.local

# Base de datos local SQLite (por si alguien la usa para pruebas)
*.sqlite3
*.sqlite3-journal
db.sqlite3

# Archivos estáticos recolectados y subidos por usuarios
/staticfiles/
/static_collected/
/media/

# Logs
*.log
logs/

# Migraciones locales temporales (las definitivas SÍ se suben)
# No ignoramos las migraciones porque deben versionarse


# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
*.dump
*.sql.gz
*.backup
pg_data/


# ------------------------------------------------------------
# Datos y archivos pesados
# ------------------------------------------------------------
# El ratings.csv pesa >30MB, no debe ir al repo
ratings.csv
*.csv.gz

# Datasets grandes en general (descomentar si hace falta)
# data/raw/
# data/processed/


# ------------------------------------------------------------
# Otros
# ------------------------------------------------------------
# Secretos y claves
*.pem
*.key
secrets.json
credentials.json

# Archivos comprimidos (normalmente no se versionan)
*.zip
*.tar
*.tar.gz
*.rar
*.csv
